---
/*
 * Fades a string in one character at a time.
 *
 * The full string is repeated in a visually-hidden span so assistive tech reads
 * it as one word rather than a pile of single-character spans; the animated
 * copy is marked presentational.
 */
interface Props {
  text: string;
}

const { text } = Astro.props;
const characters = [...text];
---

<span class="visually-hidden">{text}</span
><span role="presentation" aria-hidden="true"
  >{characters.map((character, index) => (
      <span style={`--i:${index}`}>{character}</span>
    ))}</span
>

<style>
.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip-path: inset(50%);
  white-space: nowrap;
  border: 0;
}

[role="presentation"] span {
  /* Matches the old `staggerChildren: 0.01, delayChildren: 0.5`. */
  animation: var(--character-animation);
  animation-delay: calc(0.5s + var(--i) * 0.01s);
}
</style>
