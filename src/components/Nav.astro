---
/*
 * The Radix NavigationMenu this replaces existed to render two links. The
 * active link is resolved at build time, so there is no client-side JS.
 */
const LINKS = [
  { href: '/', label: 'Home' },
  // { href: '/news', label: 'News' },
  { href: '/resources', label: 'Resources' },
];

const currentPath = Astro.url.pathname.replace(/(.)\/$/, '$1');
---

<nav>
  <ul>
    {LINKS.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={["button", { active: href === currentPath }]}
            aria-current={href === currentPath ? "page" : undefined}
          >
            {label}
          </a>
        </li>
      ))}
  </ul>
</nav>

<style>
nav {
  display: flex;
  justify-content: center;
}

ul {
  display: flex;
  justify-content: center;
  gap: var(--space-4);
  list-style: none;
  padding: 0;
}

/* .button lives in global.css — it is shared with the 404 page. */
</style>
