---
/*
 * The Radix NavigationMenu this replaces existed to render two links. The
 * active link is resolved at build time, so there is no client-side JS.
 */
const LINKS = [
  { href: '/', label: 'Home' },
  // { href: '/news', label: 'News' },
  { href: '/resources', label: 'Resources' },
];

const currentPath = Astro.url.pathname.replace(/(.)\/$/, '$1');
---

<nav>
  <ul>
    {LINKS.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={["button", { active: href === currentPath }]}
            aria-current={href === currentPath ? "page" : undefined}
          >
            {label}
          </a>
        </li>
      ))}
  </ul>
</nav>

<style>
nav {
  display: flex;
  justify-content: center;
}

ul {
  display: flex;
  justify-content: center;
  gap: var(--space-4);
  list-style: none;
  padding: 0;
}

.button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 40px;
  padding: 0 var(--space-4);
  border-radius: var(--radius-button);
  font-weight: var(--font-weight-medium);
  color: var(--accent-12);
  text-decoration: none;
  box-shadow:
    inset 0 0 0 1px var(--accent-a7),
    inset 0 0 0 1px var(--gray-a11);
}

.button.active {
  background-color: var(--accent-a3);
  box-shadow: none;
}
</style>
