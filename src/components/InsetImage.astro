---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

/*
 * An image that bleeds to the edges of its containing <Section>, cancelling the
 * card's padding.
 */
interface Props {
  src: ImageMetadata;
  alt: string;
}

const { src, alt } = Astro.props;
---

<div class="inset">
  <Image src={src} alt={alt} />
</div>

<style>
.inset {
  margin: calc(-1 * var(--card-padding));
  border-radius: var(--radius-card);
  overflow: hidden;
}

img {
  display: block;
  object-fit: cover;
  width: 100%;
  height: auto;
  /* Holds the layout and covers the gap while the image loads. */
  background-color: var(--gray-5);
}
</style>
